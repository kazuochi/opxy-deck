{
  "app": "Claude Code",
  "chime": "Glass",
  "controls": {
    "enc1.click": {
      "action": "submit",
      "label": "encoder 1 click → submit"
    },
    "enc1.turn": {
      "action": "select",
      "label": "encoder 1 turn → select",
      "mode": "absolute"
    },
    "enc2.click": {
      "action": "layer_toggle",
      "label": "encoder 2 click → edit layer (auto-exits 1.5s after last twist)",
      "layer": "edit",
      "timeoutMs": 1500
    },
    "enc2.turn": {
      "action": "effort",
      "label": "encoder 2 turn → effort",
      "layers": {
        "edit": {
          "action": "turn",
          "ccw": "Backspace",
          "cw": "Right",
          "label": "edit layer: ccw deletes a char per detent, cw walks cursor right"
        }
      },
      "mode": "absolute"
    },
    "enc3.turn": {
      "action": "scroll",
      "invert": true,
      "label": "encoder 3 turn → scroll",
      "mode": "absolute"
    },
    "enc4.turn": {
      "action": "scroll_page",
      "invert": true,
      "label": "encoder 4 turn → scroll_page",
      "mode": "absolute"
    },
    "kb.b1": {
      "action": "model_picker",
      "label": "key num 2 → model_picker"
    },
    "kb.w12": {
      "action": "model_picker"
    },
    "kb.w13": {
      "action": "effort_command"
    },
    "key_audio": {
      "action": "key",
      "chord": "C-u",
      "label": "audio → kill to line start (nuke the draft)"
    },
    "key_bar": {
      "action": "key",
      "chord": "C-y",
      "label": "bar → yank back what was killed (undo delete)"
    },
    "key_com": {
      "action": "key",
      "chord": "Backspace",
      "label": "com → backspace",
      "repeat": true
    },
    "key_seq": {
      "action": "key",
      "chord": "C-w",
      "label": "seq → delete word (readline kill; push per word)"
    },
    "transport.play": {
      "action": "submit",
      "label": "play → submit"
    },
    "transport.record": {
      "action": "ptt",
      "label": "record → ptt (hold style — pairs with /voice hold)",
      "style": "hold"
    },
    "transport.stop": {
      "action": "esc",
      "label": "stop → esc"
    }
  }
}