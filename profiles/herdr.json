{
  "app" : "herdr (multi-agent)",
  "chime" : "Ping",
  "controls" : {
    "enc1.click" : {
      "action" : "submit",
      "label" : "encoder 1 click → submit"
    },
    "enc1.turn" : {
      "action" : "select",
      "invert" : true,
      "label" : "encoder 1 turn → select",
      "mode" : "absolute"
    },
    "enc2.click" : {
      "action" : "submit",
      "label" : "encoder 2 click → submit"
    },
    "enc2.turn" : {
      "action" : "effort",
      "label" : "encoder 2 turn → effort",
      "mode" : "absolute"
    },
    "enc3.turn" : {
      "action" : "scroll",
      "label" : "encoder 3 turn → scroll",
      "mode" : "absolute"
    },
    "enc4.turn" : {
      "action" : "scroll_page",
      "label" : "encoder 4 turn → scroll_page",
      "mode" : "absolute"
    },
    "kb.b1" : {
      "action" : "model_picker",
      "label" : "key num 2 → model_picker"
    },
    "kb.w1" : {
      "action" : "effort_command",
      "label" : "key ✋ → effort_command"
    },
    "kb.w2" : {
      "action" : "thinking_toggle",
      "label" : "key ÷ → thinking_toggle"
    },
    "transport.play" : {
      "action" : "submit",
      "label" : "play → submit"
    },
    "transport.record" : {
      "action" : "ptt",
      "label" : "record → ptt"
    },
    "transport.stop" : {
      "action" : "esc",
      "label" : "stop → esc"
    },
    "step1" : {
      "action" : "shell",
      "command" : "herdr pane focus --direction left",
      "label" : "step 1 → herdr focus left (h)"
    },
    "step2" : {
      "action" : "shell",
      "command" : "herdr pane focus --direction down",
      "label" : "step 2 → herdr focus down (j)"
    },
    "step3" : {
      "action" : "shell",
      "command" : "herdr pane focus --direction up",
      "label" : "step 3 → herdr focus up (k)"
    },
    "step4" : {
      "action" : "shell",
      "command" : "herdr pane focus --direction right",
      "label" : "step 4 → herdr focus right (l)"
    },
    "step5" : {
      "action" : "shell",
      "command" : "herdr pane zoom --toggle",
      "label" : "step 5 → herdr zoom toggle"
    },
    "step6" : {
      "action" : "shell",
      "command" : "herdr agent start \"claude-$(date +%H%M%S)\" --split right --focus -- claude",
      "label" : "step 6 → new Claude agent in right split"
    },
    "step16" : {
      "action" : "profile_cycle",
      "label" : "step 16 → cycle profile (back to claude-code)"
    }
  }
}
